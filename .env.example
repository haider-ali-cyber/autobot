# =============================================
# BYBIT API KEYS (Bybit.com > API Management)
# =============================================
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# true = testnet (practice), false = real trading
BYBIT_TESTNET=true

# =============================================
# TRADING CONFIGURATION
# =============================================
MAX_STOP_LOSS_USD=0.6
MIN_TAKE_PROFIT_USD=0.4
MAX_TAKE_PROFIT_USD=1.0
MAX_OPEN_TRADES=100
INITIAL_CAPITAL=100.0

# =============================================
# RISK MANAGEMENT
# =============================================
RISK_PER_TRADE_PERCENT=1.0
MAX_DAILY_LOSS_USD=10.0

# =============================================
# MODE
# true = paper trading (no real money)
# false = live trading (real money)
# =============================================
PAPER_TRADING=true

# =============================================
# SERVER PORTS
# =============================================
API_PORT=8000
